{
  "name": "lev-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "validate:records": "node scripts/validate-records.mjs",
    "audit:data": "node scripts/audit-data-integrity.mjs",
    "audit:data:sustainability": "node scripts/data-sustainability-report.mjs",
    "audit:artifacts": "node scripts/artifact-retention-report.mjs",
    "audit:staged-archive-readiness": "node scripts/staged-archive-readiness.mjs",
    "manifest:staged-records": "node scripts/staged-records-manifest.mjs",
    "sync:research-planning": "node scripts/seed-research-planning.mjs && node scripts/seed-work-triage.mjs",
    "sync:work-triage": "node scripts/seed-work-triage.mjs",
    "lint:public-copy": "node scripts/public-copy-lint.mjs",
    "audit:trials": "node scripts/trial-watch-report.mjs",
    "audit:reader-tasks": "node scripts/reader-task-audit.mjs",
    "audit:editorial": "node scripts/editorial-quality.mjs",
    "audit:editorial:ratchet": "node scripts/editorial-quality.mjs --write --max-copy-warnings 269 --max-reader-warnings 0",
    "story:current": "node scripts/current-lev-story.mjs",
    "research:bundle": "node scripts/research-bundle.mjs",
    "research:review-evidence": "node scripts/review-evidence.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.8.3"
  }
}
