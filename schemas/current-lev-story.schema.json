{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./current-lev-story.schema.json",
  "title": "Current LEV story",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "summary",
    "date",
    "current_evidence_picture",
    "what_changed",
    "before_now_next",
    "recent_developments",
    "what_to_watch_next",
    "where_better_evidence_is_needed",
    "what_would_change_the_outlook",
    "track_examples_to_inspect",
    "revision"
  ],
  "properties": {
    "slug": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "$ref": "./common.schema.json#/$defs/isoDate"
    },
    "current_evidence_picture": {
      "type": "string",
      "minLength": 1
    },
    "what_changed": {
      "type": "string",
      "minLength": 1
    },
    "before_now_next": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/storyStep"
      }
    },
    "recent_developments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/recentDevelopment"
      }
    },
    "what_to_watch_next": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/itemToWatchNext"
      }
    },
    "where_better_evidence_is_needed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/betterEvidenceNeed"
      }
    },
    "what_would_change_the_outlook": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/outlookChangeItem"
      }
    },
    "track_examples_to_inspect": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/trackExampleToInspect"
      }
    },
    "revision": {
      "$ref": "#/$defs/revisionMeta"
    },
    "related_state_of_field_slug": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "related_publication_event_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/publicationEventRef"
      },
      "uniqueItems": true
    },
    "related_outlook_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/outlookRef"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "storyStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "title",
        "summary"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "recentDevelopment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "summary",
        "impact_on_outlook",
        "subject_type",
        "subject_id"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "impact_on_outlook": {
          "type": "string",
          "minLength": 1
        },
        "subject_type": {
          "$ref": "./common.schema.json#/$defs/subjectType"
        },
        "subject_id": {
          "$ref": "./common.schema.json#/$defs/identifier"
        },
        "related_publication_event_ids": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/publicationEventRef"
          },
          "uniqueItems": true
        },
        "related_outlook_ids": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/outlookRef"
          },
          "uniqueItems": true
        }
      }
    },
    "itemToWatchNext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "summary",
        "what_to_look_for",
        "subject_type",
        "subject_id"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "what_to_look_for": {
          "type": "string",
          "minLength": 1
        },
        "subject_type": {
          "$ref": "./common.schema.json#/$defs/subjectType"
        },
        "subject_id": {
          "$ref": "./common.schema.json#/$defs/identifier"
        },
        "related_outlook_ids": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/outlookRef"
          },
          "uniqueItems": true
        }
      }
    },
    "betterEvidenceNeed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "reason",
        "rationale",
        "what_better_evidence_would_show",
        "subject_type",
        "subject_id"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "enum": [
            "clear_next_step",
            "underbuilt_evidence",
            "early_promise",
            "blocking_gap"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "what_better_evidence_would_show": {
          "type": "string",
          "minLength": 1
        },
        "subject_type": {
          "$ref": "./common.schema.json#/$defs/subjectType"
        },
        "subject_id": {
          "$ref": "./common.schema.json#/$defs/identifier"
        },
        "related_outlook_ids": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/outlookRef"
          },
          "uniqueItems": true
        }
      }
    },
    "outlookChangeItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direction",
        "label",
        "summary"
      ],
      "properties": {
        "direction": {
          "type": "string",
          "enum": [
            "more_optimistic",
            "less_optimistic",
            "needs_attention"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "related_outlook_ids": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/outlookRef"
          },
          "uniqueItems": true
        }
      }
    },
    "trackExampleToInspect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "title",
        "summary",
        "href"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "pattern": "^/"
        },
        "related_outlook_ids": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/outlookRef"
          },
          "uniqueItems": true
        }
      }
    },
    "revisionMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "last_reviewed",
        "review_reason",
        "review_due",
        "triggers"
      ],
      "properties": {
        "last_reviewed": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "review_reason": {
          "type": "string",
          "minLength": 1
        },
        "review_due": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "trigger_type",
              "description"
            ],
            "properties": {
              "trigger_type": {
                "type": "string",
                "enum": [
                  "new_publication_event",
                  "outlook_change",
                  "timing_window_change",
                  "state_of_field_rollup",
                  "review_due",
                  "human_editorial_request"
                ]
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "threshold": {
                "type": "string"
              },
              "related_outlook_ids": {
                "type": "array",
                "items": {
                  "$ref": "./common.schema.json#/$defs/outlookRef"
                },
                "uniqueItems": true
              }
            }
          }
        },
        "observed_state_of_field_slug": {
          "$ref": "./common.schema.json#/$defs/identifier"
        },
        "observed_latest_publication_event_id": {
          "$ref": "./common.schema.json#/$defs/publicationEventRef"
        },
        "observed_outlook_states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observedOutlookState"
          },
          "uniqueItems": true
        }
      }
    },
    "observedOutlookState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outlook_id",
        "subject_type",
        "subject_id",
        "evidence_stage",
        "momentum",
        "confidence",
        "last_updated",
        "fingerprint"
      ],
      "properties": {
        "outlook_id": {
          "$ref": "./common.schema.json#/$defs/outlookRef"
        },
        "subject_type": {
          "$ref": "./common.schema.json#/$defs/subjectType"
        },
        "subject_id": {
          "$ref": "./common.schema.json#/$defs/identifier"
        },
        "evidence_stage": {
          "$ref": "./common.schema.json#/$defs/progressStage"
        },
        "momentum": {
          "$ref": "./common.schema.json#/$defs/momentum"
        },
        "confidence": {
          "$ref": "./common.schema.json#/$defs/confidence"
        },
        "evidence_gap": {
          "type": "string"
        },
        "strongest_evidence": {
          "type": "string"
        },
        "last_updated": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{16}$"
        }
      }
    }
  }
}
