{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./study.schema.json",
  "title": "Study record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "study_type",
    "status",
    "source_ids"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "study"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "name": {
      "type": "string"
    },
    "short_name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "created_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "updated_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "study_type": {
      "$ref": "./common.schema.json#/$defs/studyType"
    },
    "status": {
      "$ref": "./common.schema.json#/$defs/studyStatus"
    },
    "phase": {
      "$ref": "./common.schema.json#/$defs/phase"
    },
    "population": {
      "type": "string"
    },
    "model_system": {
      "type": "string"
    },
    "sample_size": {
      "type": "integer",
      "minimum": 0
    },
    "intervention_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/interventionRef"
      },
      "uniqueItems": true
    },
    "hallmark_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/hallmarkRef"
      },
      "uniqueItems": true
    },
    "track_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/trackRef"
      },
      "uniqueItems": true
    },
    "endpoint_categories": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/endpointCategory"
      },
      "uniqueItems": true
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./common.schema.json#/$defs/sourceRef"
      },
      "uniqueItems": true
    },
    "registry_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "dates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start_date": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "end_date": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        }
      }
    },
    "trial_details": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registry_last_updated": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "registry_last_checked": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "primary_completion_date": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "study_completion_date": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "completion_date_kind": {
          "type": "string",
          "enum": [
            "actual",
            "estimated",
            "unknown"
          ]
        },
        "results_status": {
          "type": "string",
          "enum": [
            "posted",
            "not_posted",
            "pending",
            "unknown"
          ]
        },
        "results_first_posted_date": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "results_due_date": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "expected_results_window": {
          "type": "string",
          "minLength": 1
        },
        "horizon_note": {
          "type": "string",
          "minLength": 1
        },
        "why_it_matters": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
