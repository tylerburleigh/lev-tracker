{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/data/evidence-index.schema.json",
  "title": "LEV Tracker evidence index export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_url",
    "export_type",
    "generated_at",
    "last_public_update",
    "canonical_path",
    "page_path",
    "applied_filters",
    "caveats",
    "summary",
    "facet_options",
    "saved_views",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "schema_url": {
      "const": "/data/evidence-index.schema.json"
    },
    "export_type": {
      "const": "lev_tracker_evidence_index"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_public_update": {
      "type": "string"
    },
    "canonical_path": {
      "type": "string",
      "pattern": "^/data/evidence-index\\.json"
    },
    "page_path": {
      "type": "string",
      "pattern": "^/evidence"
    },
    "applied_filters": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "caveats": {
      "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "facet_options": {
      "$ref": "#/$defs/facetOptions"
    },
    "saved_views": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/savedView"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceFinding"
      }
    }
  },
  "$defs": {
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "filterOption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "label"
      ],
      "properties": {
        "value": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_finding_count",
        "filtered_finding_count",
        "returned_finding_count",
        "human_finding_count",
        "animal_finding_count",
        "positive_finding_count",
        "null_or_negative_finding_count",
        "quality_class_counts",
        "source_count",
        "multi_track_source_count",
        "track_count",
        "intervention_count"
      ],
      "properties": {
        "total_finding_count": {
          "$ref": "#/$defs/count"
        },
        "filtered_finding_count": {
          "$ref": "#/$defs/count"
        },
        "returned_finding_count": {
          "$ref": "#/$defs/count"
        },
        "human_finding_count": {
          "$ref": "#/$defs/count"
        },
        "animal_finding_count": {
          "$ref": "#/$defs/count"
        },
        "positive_finding_count": {
          "$ref": "#/$defs/count"
        },
        "null_or_negative_finding_count": {
          "$ref": "#/$defs/count"
        },
        "quality_class_counts": {
          "$ref": "#/$defs/qualityClassCounts"
        },
        "source_count": {
          "$ref": "#/$defs/count"
        },
        "multi_track_source_count": {
          "$ref": "#/$defs/count"
        },
        "track_count": {
          "$ref": "#/$defs/count"
        },
        "intervention_count": {
          "$ref": "#/$defs/count"
        }
      }
    },
    "facetOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hallmarks",
        "tracks",
        "interventions",
        "evidence_tiers",
        "directions",
        "confidences",
        "endpoints",
        "source_types",
        "coverage_confidences",
        "quality_classes",
        "limitations",
        "human_relevance",
        "consistency_patterns",
        "species",
        "source_reuse",
        "sorts"
      ],
      "properties": {
        "hallmarks": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "tracks": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "interventions": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "evidence_tiers": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "directions": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "confidences": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "endpoints": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "source_types": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "coverage_confidences": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "quality_classes": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "limitations": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "human_relevance": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "consistency_patterns": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "species": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "source_reuse": {
          "$ref": "#/$defs/filterOptionArray"
        },
        "sorts": {
          "$ref": "#/$defs/filterOptionArray"
        }
      }
    },
    "filterOptionArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/filterOption"
      }
    },
    "qualityClass": {
      "enum": [
        "stronger_human_signal",
        "human_biomarker_or_limited_function",
        "preclinical_or_mechanistic",
        "review_or_context",
        "registry_or_no_results",
        "limiting_or_null"
      ]
    },
    "studyDesignFlag": {
      "enum": [
        "randomized",
        "controlled",
        "registry_linked",
        "result_posted",
        "no_results_registry",
        "review_or_meta_analysis",
        "preclinical",
        "human_interventional",
        "observational_or_real_world",
        "animal_or_model",
        "mechanistic_or_in_vitro"
      ]
    },
    "humanRelevanceFlag": {
      "enum": [
        "older_adults",
        "healthy_adults",
        "disease_cohort",
        "human_biomarker",
        "functional_endpoint",
        "clinical_or_healthspan_endpoint",
        "safety_endpoint",
        "animal_only",
        "nonhuman_model"
      ]
    },
    "limitationTag": {
      "enum": [
        "low_confidence",
        "surrogate_or_biomarker_endpoint",
        "animal_only",
        "short_duration",
        "small_sample",
        "underpowered_or_exploratory",
        "confounded_or_observational",
        "mixed_or_null_direction",
        "no_posted_results",
        "safety_unresolved",
        "review_not_primary_evidence",
        "industry_or_conflict_caveat"
      ]
    },
    "consistencyClass": {
      "enum": [
        "consistent_positive_signal",
        "mixed_or_conflicting_signal",
        "animal_positive_human_limited",
        "biomarker_positive_function_mixed",
        "single_source_or_unreplicated",
        "registry_results_gap",
        "insufficient_mapped_evidence"
      ]
    },
    "consistencyPattern": {
      "enum": [
        "positive_and_null_or_negative",
        "animal_positive_human_null_or_mixed",
        "biomarker_positive_function_mixed_or_null",
        "single_source_positive_signal",
        "registry_no_results_with_positive_claims",
        "preclinical_positive_no_human",
        "review_context_without_primary",
        "mixed_direction_findings",
        "replicated_human_positive_signal"
      ]
    },
    "qualityClassCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stronger_human_signal",
        "human_biomarker_or_limited_function",
        "preclinical_or_mechanistic",
        "review_or_context",
        "registry_or_no_results",
        "limiting_or_null"
      ],
      "properties": {
        "stronger_human_signal": {
          "$ref": "#/$defs/count"
        },
        "human_biomarker_or_limited_function": {
          "$ref": "#/$defs/count"
        },
        "preclinical_or_mechanistic": {
          "$ref": "#/$defs/count"
        },
        "review_or_context": {
          "$ref": "#/$defs/count"
        },
        "registry_or_no_results": {
          "$ref": "#/$defs/count"
        },
        "limiting_or_null": {
          "$ref": "#/$defs/count"
        }
      }
    },
    "sourceQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_type",
        "source_type_label",
        "registry_ids"
      ],
      "properties": {
        "source_id": {
          "type": "string"
        },
        "source_type": {
          "type": "string"
        },
        "source_type_label": {
          "type": "string"
        },
        "year": {
          "type": "integer"
        },
        "published_on": {
          "type": "string"
        },
        "registry_ids": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        },
        "doi": {
          "type": "string"
        },
        "pmid": {
          "type": "string"
        }
      }
    },
    "studyQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "study_id",
        "study_type",
        "study_type_label",
        "status",
        "status_label",
        "registry_ids"
      ],
      "properties": {
        "study_id": {
          "type": "string"
        },
        "study_type": {
          "type": "string"
        },
        "study_type_label": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "status_label": {
          "type": "string"
        },
        "phase": {
          "type": "string"
        },
        "phase_label": {
          "type": "string"
        },
        "population": {
          "type": "string"
        },
        "model_system": {
          "type": "string"
        },
        "sample_size": {
          "type": "integer",
          "minimum": 0
        },
        "registry_ids": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        },
        "results_status": {
          "type": "string"
        },
        "results_status_label": {
          "type": "string"
        },
        "watch_status": {
          "type": "string"
        },
        "watch_status_label": {
          "type": "string"
        }
      }
    },
    "evidenceQualityProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality_class",
        "quality_class_label",
        "quality_class_meaning",
        "quality_class_reason",
        "evidence_strength_score",
        "study_design_flags",
        "study_design_flag_labels",
        "human_relevance_flags",
        "human_relevance_flag_labels",
        "limitation_tags",
        "limitation_labels",
        "source_quality",
        "study_quality"
      ],
      "properties": {
        "quality_class": {
          "$ref": "#/$defs/qualityClass"
        },
        "quality_class_label": {
          "type": "string"
        },
        "quality_class_meaning": {
          "type": "string"
        },
        "quality_class_reason": {
          "type": "string"
        },
        "evidence_strength_score": {
          "type": "number"
        },
        "study_design_flags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/studyDesignFlag"
          }
        },
        "study_design_flag_labels": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        },
        "human_relevance_flags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/humanRelevanceFlag"
          }
        },
        "human_relevance_flag_labels": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        },
        "limitation_tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/limitationTag"
          }
        },
        "limitation_labels": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        },
        "source_quality": {
          "anyOf": [
            {
              "$ref": "#/$defs/sourceQuality"
            },
            {
              "type": "null"
            }
          ]
        },
        "study_quality": {
          "anyOf": [
            {
              "$ref": "#/$defs/studyQuality"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "evidenceConsistencyContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "track_name",
        "href",
        "consistency_class",
        "consistency_class_label",
        "consistency_class_meaning",
        "consistency_reason",
        "patterns",
        "pattern_labels"
      ],
      "properties": {
        "track_id": {
          "type": "string"
        },
        "track_name": {
          "type": "string"
        },
        "href": {
          "type": "string",
          "pattern": "^/tracks/"
        },
        "consistency_class": {
          "$ref": "#/$defs/consistencyClass"
        },
        "consistency_class_label": {
          "type": "string"
        },
        "consistency_class_meaning": {
          "type": "string"
        },
        "consistency_reason": {
          "type": "string"
        },
        "patterns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/consistencyPattern"
          }
        },
        "pattern_labels": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        }
      }
    },
    "savedView": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "summary",
        "kind",
        "path",
        "count"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "evidence",
            "trials"
          ]
        },
        "path": {
          "type": "string"
        },
        "data_path": {
          "type": "string"
        },
        "count": {
          "$ref": "#/$defs/count"
        }
      }
    },
    "linkedHallmark": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "href"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "href": {
          "type": "string",
          "pattern": "^/hallmarks/"
        }
      }
    },
    "trackContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "href",
        "primary_hallmark_id",
        "primary_hallmark_name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "href": {
          "type": "string",
          "pattern": "^/tracks/"
        },
        "primary_hallmark_id": {
          "type": "string"
        },
        "primary_hallmark_name": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        },
        "stage_label": {
          "type": "string"
        },
        "confidence": {
          "type": "string"
        },
        "read_firmness_label": {
          "type": "string"
        },
        "coverage_verdict": {
          "type": "string"
        },
        "coverage_verdict_label": {
          "type": "string"
        },
        "coverage_confidence": {
          "type": "string"
        },
        "coverage_confidence_label": {
          "type": "string"
        },
        "observed_research_density": {
          "type": "string"
        },
        "observed_research_density_label": {
          "type": "string"
        }
      }
    },
    "evidenceFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "href",
        "statement",
        "source_id",
        "intervention_ids",
        "track_ids",
        "hallmark_ids",
        "endpoint_category",
        "endpoint_category_label",
        "direction",
        "direction_label",
        "evidence_tier",
        "evidence_tier_label",
        "is_human_evidence",
        "confidence",
        "read_firmness_label",
        "evidence_strength_score",
        "species",
        "species_label",
        "source_reuse_track_count",
        "source_reuse_track_ids",
        "source",
        "study",
        "interventions",
        "track_contexts",
        "hallmarks",
        "quality",
        "consistency_contexts",
        "caveats"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "href": {
          "type": "string",
          "pattern": "^/findings/"
        },
        "statement": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "source_id": {
          "type": "string"
        },
        "study_id": {
          "type": "string"
        },
        "intervention_ids": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        },
        "track_ids": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        },
        "hallmark_ids": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        },
        "endpoint_category": {
          "type": "string"
        },
        "endpoint_category_label": {
          "type": "string"
        },
        "direction": {
          "type": "string"
        },
        "direction_label": {
          "type": "string"
        },
        "evidence_tier": {
          "type": "string"
        },
        "evidence_tier_label": {
          "type": "string"
        },
        "is_human_evidence": {
          "type": "boolean"
        },
        "confidence": {
          "type": "string"
        },
        "read_firmness_label": {
          "type": "string"
        },
        "evidence_strength_score": {
          "type": "number"
        },
        "species": {
          "enum": [
            "human",
            "animal",
            "nonhuman"
          ]
        },
        "species_label": {
          "type": "string"
        },
        "source_type": {
          "type": "string"
        },
        "source_type_label": {
          "type": "string"
        },
        "source_year": {
          "type": "integer"
        },
        "source_published_on": {
          "type": "string"
        },
        "source_reuse_track_count": {
          "$ref": "#/$defs/count"
        },
        "source_reuse_track_ids": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        },
        "population_or_model": {
          "type": "string"
        },
        "time_horizon": {
          "type": "string"
        },
        "quantitative_note": {
          "type": "string"
        },
        "source": {
          "anyOf": [
            {
              "$ref": "/data/evidence-map.schema.json#/$defs/source"
            },
            {
              "type": "null"
            }
          ]
        },
        "study": {
          "anyOf": [
            {
              "$ref": "/data/evidence-map.schema.json#/$defs/study"
            },
            {
              "type": "null"
            }
          ]
        },
        "interventions": {
          "type": "array",
          "items": {
            "$ref": "/data/evidence-map.schema.json#/$defs/intervention"
          }
        },
        "track_contexts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/trackContext"
          }
        },
        "hallmarks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/linkedHallmark"
          }
        },
        "quality": {
          "$ref": "#/$defs/evidenceQualityProfile"
        },
        "consistency_contexts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceConsistencyContext"
          }
        },
        "caveats": {
          "$ref": "/data/evidence-map.schema.json#/$defs/stringArray"
        }
      }
    }
  }
}
