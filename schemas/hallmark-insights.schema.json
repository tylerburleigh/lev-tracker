{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./hallmark-insights.schema.json",
  "title": "Hallmark insight content",
  "type": "array",
  "minItems": 12,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "hallmark_id",
      "overview",
      "next_stage_requirement",
      "key_question",
      "last_reviewed",
      "review_reason",
      "related_outlook_ids"
    ],
    "properties": {
      "hallmark_id": {
        "$ref": "./common.schema.json#/$defs/hallmarkRef"
      },
      "overview": {
        "type": "string",
        "minLength": 1
      },
      "next_stage_requirement": {
        "type": "string",
        "minLength": 1
      },
      "key_question": {
        "type": "string",
        "minLength": 1
      },
      "last_reviewed": {
        "$ref": "./common.schema.json#/$defs/isoDate"
      },
      "review_reason": {
        "type": "string",
        "minLength": 1
      },
      "related_outlook_ids": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "./common.schema.json#/$defs/outlookRef"
        },
        "uniqueItems": true
      },
      "related_publication_event_ids": {
        "type": "array",
        "items": {
          "$ref": "./common.schema.json#/$defs/publicationEventRef"
        },
        "uniqueItems": true
      }
    }
  }
}
