{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./hallmark-insights.schema.json",
  "title": "Hallmark insight content",
  "type": "array",
  "minItems": 12,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "hallmark_id",
      "overview",
      "next_stage_requirement",
      "key_question"
    ],
    "properties": {
      "hallmark_id": {
        "$ref": "./common.schema.json#/$defs/hallmarkRef"
      },
      "overview": {
        "type": "string",
        "minLength": 1
      },
      "next_stage_requirement": {
        "type": "string",
        "minLength": 1
      },
      "key_question": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
