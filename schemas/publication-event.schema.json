{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./publication-event.schema.json",
  "title": "Publication event record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "event_type",
    "published_at",
    "published_by",
    "published_targets"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "publication_event"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "name": {
      "type": "string"
    },
    "short_name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "created_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "updated_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "candidate_bundle_id": {
      "$ref": "./common.schema.json#/$defs/candidateBundleRef"
    },
    "publication_route": {
      "enum": [
        "candidate_bundle",
        "direct_activity_publish",
        "direct_editorial_update"
      ],
      "description": "Optional route marker for public updates that are intentionally not owned by a candidate bundle."
    },
    "event_type": {
      "$ref": "./common.schema.json#/$defs/publicationEventType"
    },
    "published_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "published_by": {
      "type": "string"
    },
    "published_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "record_type",
          "record_id",
          "action"
        ],
        "properties": {
          "record_type": {
            "$ref": "./common.schema.json#/$defs/recordType"
          },
          "record_id": {
            "$ref": "./common.schema.json#/$defs/identifier"
          },
          "action": {
            "$ref": "./common.schema.json#/$defs/publicationTargetAction"
          }
        }
      }
    },
    "affected_outlook_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/outlookRef"
      },
      "uniqueItems": true
    },
    "approving_evidence_review_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/evidenceReviewRef"
      },
      "uniqueItems": true
    },
    "change_note": {
      "type": "string"
    }
  }
}
