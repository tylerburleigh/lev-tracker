{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./state-of-the-field-edition.schema.json",
  "title": "State of the field edition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "summary",
    "lede",
    "bottom_line",
    "field_change_status",
    "field_change_note",
    "period_start",
    "period_end",
    "period_label",
    "date",
    "bullets",
    "what_changed",
    "current_context",
    "what_did_not_change",
    "why_it_matters",
    "trial_horizon",
    "signals_to_watch",
    "evidence_gaps",
    "track_examples",
    "reader_takeaways",
    "review_basis",
    "last_reviewed",
    "review_reason",
    "revision_history"
  ],
  "$defs": {
    "relatedOutlookIds": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/outlookRef"
      },
      "uniqueItems": true
    },
    "relatedPublicationEventIds": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/publicationEventRef"
      },
      "uniqueItems": true
    },
    "relatedActivityItemIds": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/activityItemRef"
      },
      "uniqueItems": true
    },
    "changeKind": {
      "type": "string",
      "enum": [
        "outlook_changed",
        "field_signal",
        "context_only",
        "activity_without_results"
      ]
    },
    "fieldChangeStatus": {
      "type": "string",
      "enum": [
        "material_change",
        "mixed",
        "no_material_change"
      ]
    },
    "reviewBasisKey": {
      "type": "string",
      "enum": [
        "public_updates",
        "outlooks",
        "trial_horizon",
        "current_context",
        "field_activity",
        "other"
      ]
    },
    "reviewBasisItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label",
        "count",
        "unit_singular",
        "summary"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/reviewBasisKey"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "unit_singular": {
          "type": "string",
          "minLength": 1
        },
        "unit_plural": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reviewBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "items",
        "caveats"
      ],
      "properties": {
        "items": {
          "type": "array",
          "minItems": 4,
          "items": {
            "$ref": "#/$defs/reviewBasisItem"
          }
        },
        "caveats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "changeItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_kind",
        "happened_on",
        "title",
        "summary"
      ],
      "properties": {
        "change_kind": {
          "$ref": "#/$defs/changeKind"
        },
        "happened_on": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "interpretation": {
          "type": "string",
          "minLength": 1
        },
        "related_outlook_ids": {
          "$ref": "#/$defs/relatedOutlookIds"
        },
        "related_publication_event_ids": {
          "$ref": "#/$defs/relatedPublicationEventIds"
        }
      }
    },
    "labeledTextItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "summary"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "related_outlook_ids": {
          "$ref": "#/$defs/relatedOutlookIds"
        },
        "related_publication_event_ids": {
          "$ref": "#/$defs/relatedPublicationEventIds"
        }
      }
    },
    "trialHorizonItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "summary"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "study_id": {
          "$ref": "./common.schema.json#/$defs/studyRef"
        },
        "related_outlook_ids": {
          "$ref": "#/$defs/relatedOutlookIds"
        },
        "related_publication_event_ids": {
          "$ref": "#/$defs/relatedPublicationEventIds"
        }
      }
    },
    "fieldActivityItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "happened_on",
        "label",
        "summary"
      ],
      "properties": {
        "happened_on": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "related_activity_item_ids": {
          "$ref": "#/$defs/relatedActivityItemIds"
        },
        "related_publication_event_ids": {
          "$ref": "#/$defs/relatedPublicationEventIds"
        }
      }
    },
    "trackExample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "title",
        "summary",
        "href"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "related_outlook_ids": {
          "$ref": "#/$defs/relatedOutlookIds"
        }
      }
    },
    "revisionKind": {
      "type": "string",
      "enum": [
        "initial_publication",
        "post_hoc_material_correction",
        "post_hoc_context_note",
        "copy_or_structure_revision"
      ]
    },
    "revisionHistoryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewed_on",
        "revision_kind",
        "period_interpretation_changed",
        "summary"
      ],
      "properties": {
        "reviewed_on": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "revision_kind": {
          "$ref": "#/$defs/revisionKind"
        },
        "period_interpretation_changed": {
          "type": "boolean"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "related_outlook_ids": {
          "$ref": "#/$defs/relatedOutlookIds"
        },
        "related_publication_event_ids": {
          "$ref": "#/$defs/relatedPublicationEventIds"
        }
      }
    }
  },
  "properties": {
    "slug": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "lede": {
      "type": "string",
      "minLength": 1
    },
    "bottom_line": {
      "type": "string",
      "minLength": 1
    },
    "field_change_status": {
      "$ref": "#/$defs/fieldChangeStatus"
    },
    "field_change_note": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "$ref": "./common.schema.json#/$defs/isoDate"
    },
    "period_start": {
      "$ref": "./common.schema.json#/$defs/isoDate"
    },
    "period_end": {
      "$ref": "./common.schema.json#/$defs/isoDate"
    },
    "period_label": {
      "type": "string",
      "minLength": 1
    },
    "bullets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "what_changed": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/changeItem"
      }
    },
    "current_context": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/labeledTextItem"
      }
    },
    "what_did_not_change": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "why_it_matters": {
      "type": "string",
      "minLength": 1
    },
    "trial_horizon": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trialHorizonItem"
      }
    },
    "field_activity": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fieldActivityItem"
      }
    },
    "signals_to_watch": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/labeledTextItem"
      }
    },
    "evidence_gaps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/labeledTextItem"
      }
    },
    "track_examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/trackExample"
      }
    },
    "reader_takeaways": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_basis": {
      "$ref": "#/$defs/reviewBasis"
    },
    "last_reviewed": {
      "$ref": "./common.schema.json#/$defs/isoDate"
    },
    "review_reason": {
      "type": "string",
      "minLength": 1
    },
    "revision_history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/revisionHistoryItem"
      }
    },
    "related_publication_event_ids": {
      "$ref": "#/$defs/relatedPublicationEventIds"
    },
    "related_outlook_ids": {
      "$ref": "#/$defs/relatedOutlookIds"
    }
  }
}
