{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./state-of-the-field-edition.schema.json",
  "title": "State of the field edition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "summary",
    "date",
    "bullets",
    "last_reviewed",
    "review_reason"
  ],
  "properties": {
    "slug": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "$ref": "./common.schema.json#/$defs/isoDate"
    },
    "bullets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "last_reviewed": {
      "$ref": "./common.schema.json#/$defs/isoDate"
    },
    "review_reason": {
      "type": "string",
      "minLength": 1
    },
    "related_publication_event_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/publicationEventRef"
      },
      "uniqueItems": true
    },
    "related_outlook_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/outlookRef"
      },
      "uniqueItems": true
    }
  }
}
