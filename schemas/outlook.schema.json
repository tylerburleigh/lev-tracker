{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./outlook.schema.json",
  "title": "Outlook record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "subject_type",
    "subject_id",
    "evidence_stage",
    "momentum",
    "confidence",
    "interpretation_note",
    "last_updated"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "outlook"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "name": {
      "type": "string"
    },
    "short_name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "created_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "updated_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "subject_type": {
      "$ref": "./common.schema.json#/$defs/subjectType"
    },
    "subject_id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "evidence_stage": {
      "$ref": "./common.schema.json#/$defs/progressStage"
    },
    "momentum": {
      "$ref": "./common.schema.json#/$defs/momentum"
    },
    "confidence": {
      "$ref": "./common.schema.json#/$defs/confidence"
    },
    "main_evidence_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "strongest_current_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "interpretation_note": {
      "type": "string"
    },
    "what_would_change_the_rating": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "earliest_plausible_window": {
      "type": "string"
    },
    "supporting_finding_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/findingRef"
      },
      "uniqueItems": true
    },
    "supporting_activity_item_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/activityItemRef"
      },
      "uniqueItems": true
    },
    "supporting_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "conclusion",
          "support_role",
          "rationale",
          "finding_ids"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "outlook_field": {
            "type": "string"
          },
          "conclusion": {
            "type": "string"
          },
          "support_role": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "finding_ids": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/findingRef"
            },
            "uniqueItems": true,
            "minItems": 1
          },
          "source_ids": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/sourceRef"
            },
            "uniqueItems": true
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "supporting_source_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/sourceRef"
      },
      "uniqueItems": true
    },
    "last_updated": {
      "$ref": "./common.schema.json#/$defs/isoDate"
    }
  }
}
