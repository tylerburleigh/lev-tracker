{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./outlook.schema.json",
  "title": "Outlook record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "subject_type",
    "subject_id",
    "current_stage",
    "momentum",
    "confidence",
    "forecast_note",
    "last_updated"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "outlook"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "name": {
      "type": "string"
    },
    "short_name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "created_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "updated_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "subject_type": {
      "$ref": "./common.schema.json#/$defs/subjectType"
    },
    "subject_id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "current_stage": {
      "$ref": "./common.schema.json#/$defs/progressStage"
    },
    "momentum": {
      "$ref": "./common.schema.json#/$defs/momentum"
    },
    "confidence": {
      "$ref": "./common.schema.json#/$defs/confidence"
    },
    "main_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "best_current_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forecast_note": {
      "type": "string"
    },
    "earliest_plausible_window": {
      "type": "string"
    },
    "scenario_2036_status": {
      "$ref": "./common.schema.json#/$defs/scenario2036Status"
    },
    "supporting_finding_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/findingRef"
      },
      "uniqueItems": true
    },
    "supporting_activity_item_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/activityItemRef"
      },
      "uniqueItems": true
    },
    "supporting_source_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/sourceRef"
      },
      "uniqueItems": true
    },
    "last_updated": {
      "$ref": "./common.schema.json#/$defs/isoDate"
    }
  }
}
