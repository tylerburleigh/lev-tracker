  "$id": "/data/evidence-map.schema.json",
  "title": "LEV Tracker full evidence-map export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_url",
    "export_type",
    "generated_at",
    "last_public_update",
    "canonical_path",
    "dataset_card",
    "caveats",
    "legends",
    "summary",
    "hallmarks",
    "tracks",
    "findings",
    "sources",
    "trials",
    "source_file_patterns"
  ],
