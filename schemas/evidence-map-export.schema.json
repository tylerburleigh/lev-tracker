    "schema_version": {
      "const": "1.3.0"
    },
    "schema_url": {
      "const": "/data/evidence-map.schema.json"
    },
    "export_type": {
      "const": "lev_tracker_evidence_map"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_public_update": {
      "type": "string"
    },
    "canonical_path": {
      "const": "/data/evidence-map.json"
    },
    "dataset_card": {
      "$ref": "#/$defs/datasetCard"
    },
    "caveats": {
      "$ref": "#/$defs/stringArray"
    },
    "legends": {
      "$ref": "#/$defs/legends"
    },
    "summary": {
      "$ref": "#/$defs/fullSummary"
