{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./state-of-field-workflow.schema.json",
  "title": "State of the Field workflow state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "state_type",
    "updated_at",
    "policy",
    "editions"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "state_type": {
      "const": "state_of_field_workflow"
    },
    "updated_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_visibility",
        "draft_storage",
        "publish_gate"
      ],
      "properties": {
        "public_visibility": {
          "type": "string",
          "minLength": 1
        },
        "draft_storage": {
          "type": "string",
          "minLength": 1
        },
        "publish_gate": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "editions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/editionWorkflow"
      }
    }
  },
  "$defs": {
    "workflowStatus": {
      "enum": [
        "draft",
        "reconciling",
        "needs_surveillance",
        "in_review",
        "published",
        "blocked",
        "no_op"
      ]
    },
    "decision": {
      "enum": [
        "needs_decision",
        "no_op",
        "defer_to_next_edition",
        "add_post_hoc_context_note",
        "post_hoc_material_correction"
      ]
    },
    "checkStatus": {
      "enum": [
        "pending",
        "in_progress",
        "complete",
        "blocked",
        "not_applicable"
      ]
    },
    "editionWorkflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slug",
        "title",
        "period_start",
        "period_end",
        "period_label",
        "status",
        "status_updated_at",
        "status_note",
        "published_edition_path",
        "observed_public_story",
        "required_next_action",
        "reconciliation_items",
        "checklist"
      ],
      "properties": {
        "slug": {
          "$ref": "./common.schema.json#/$defs/identifier"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "period_start": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "period_end": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "period_label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/workflowStatus"
        },
        "status_updated_at": {
          "$ref": "./common.schema.json#/$defs/dateTime"
        },
        "status_note": {
          "type": "string",
          "minLength": 1
        },
        "published_edition_path": {
          "type": "string",
          "minLength": 1
        },
        "draft_artifact_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "observed_public_story": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "last_reviewed",
            "latest_publication_event_id",
            "related_publication_event_ids"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "last_reviewed": {
              "$ref": "./common.schema.json#/$defs/isoDate"
            },
            "latest_publication_event_id": {
              "$ref": "./common.schema.json#/$defs/publicationEventRef"
            },
            "related_publication_event_ids": {
              "type": "array",
              "items": {
                "$ref": "./common.schema.json#/$defs/publicationEventRef"
              },
              "uniqueItems": true
            }
          }
        },
        "observed_published_edition": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "last_reviewed",
            "review_reason",
            "related_publication_event_ids"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "last_reviewed": {
              "$ref": "./common.schema.json#/$defs/isoDate"
            },
            "review_reason": {
              "type": "string",
              "minLength": 1
            },
            "related_publication_event_ids": {
              "type": "array",
              "items": {
                "$ref": "./common.schema.json#/$defs/publicationEventRef"
              },
              "uniqueItems": true
            }
          }
        },
        "required_next_action": {
          "type": "string",
          "minLength": 1
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reconciliation_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reconciliationItem"
          }
        },
        "checklist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/checklistItem"
          }
        }
      }
    },
    "reconciliationItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_event_id",
        "event_date",
        "related_outlook_ids",
        "decision",
        "rationale",
        "next_action"
      ],
      "properties": {
        "publication_event_id": {
          "$ref": "./common.schema.json#/$defs/publicationEventRef"
        },
        "event_date": {
          "$ref": "./common.schema.json#/$defs/isoDate"
        },
        "related_outlook_ids": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/outlookRef"
          },
          "uniqueItems": true
        },
        "decision": {
          "$ref": "#/$defs/decision"
        },
        "period_interpretation_changed": {
          "type": "boolean"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "next_action": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "checklistItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "status"
      ],
      "properties": {
        "id": {
          "$ref": "./common.schema.json#/$defs/identifier"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/checkStatus"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
