{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./hallmarks-taxonomy.schema.json",
  "title": "Hallmarks of Aging taxonomy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "taxonomy",
    "framework_version",
    "source",
    "hallmarks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "taxonomy": {
      "type": "string",
      "const": "hallmarks_of_aging"
    },
    "framework_version": {
      "type": "string",
      "const": "2023"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "citation": {
          "type": "string"
        },
        "doi": {
          "type": "string"
        },
        "url": {
          "$ref": "./common.schema.json#/$defs/url"
        }
      }
    },
    "hallmarks": {
      "type": "array",
      "minItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "canonical_order",
          "description"
        ],
        "properties": {
          "id": {
            "$ref": "./common.schema.json#/$defs/identifier"
          },
          "name": {
            "type": "string"
          },
          "canonical_order": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
