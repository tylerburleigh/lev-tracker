{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./evidence-review.schema.json",
  "title": "Evidence review record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "candidate_bundle_id",
    "bundle_revision_number",
    "review_round",
    "review_lane",
    "reviewer_kind",
    "status",
    "verdict",
    "blocking",
    "summary",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "evidence_review"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "name": {
      "type": "string"
    },
    "short_name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "created_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "updated_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "candidate_bundle_id": {
      "$ref": "./common.schema.json#/$defs/candidateBundleRef"
    },
    "bundle_revision_number": {
      "type": "integer",
      "minimum": 1
    },
    "review_round": {
      "type": "integer",
      "minimum": 1
    },
    "review_lane": {
      "$ref": "./common.schema.json#/$defs/evidenceReviewLane"
    },
    "reviewer_kind": {
      "$ref": "./common.schema.json#/$defs/evidenceReviewerKind"
    },
    "reviewer_id": {
      "type": "string"
    },
    "skill_name": {
      "type": "string"
    },
    "status": {
      "$ref": "./common.schema.json#/$defs/evidenceReviewStatus"
    },
    "verdict": {
      "$ref": "./common.schema.json#/$defs/evidenceReviewVerdict"
    },
    "blocking": {
      "type": "boolean"
    },
    "reviewed_change_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/identifier"
      },
      "uniqueItems": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "severity",
          "category",
          "claim_or_issue",
          "why_it_matters",
          "recommended_action",
          "resolution_status"
        ],
        "properties": {
          "finding_id": {
            "$ref": "./common.schema.json#/$defs/identifier"
          },
          "severity": {
            "$ref": "./common.schema.json#/$defs/evidenceReviewFindingSeverity"
          },
          "category": {
            "$ref": "./common.schema.json#/$defs/evidenceReviewFindingCategory"
          },
          "applies_to_change_id": {
            "$ref": "./common.schema.json#/$defs/identifier"
          },
          "applies_to_record": {
            "$ref": "./common.schema.json#/$defs/recordLocator"
          },
          "claim_or_issue": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          },
          "recommended_action": {
            "type": "string"
          },
          "resolution_status": {
            "$ref": "./common.schema.json#/$defs/evidenceReviewFindingResolution"
          }
        }
      }
    }
  }
}
