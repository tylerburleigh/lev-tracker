{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./activity-item.schema.json",
  "title": "Activity item record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "name",
    "activity_type",
    "activity_lane",
    "occurred_on"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "activity_item"
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "name": {
      "type": "string"
    },
    "short_name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "created_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "updated_at": {
      "$ref": "./common.schema.json#/$defs/dateTime"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "activity_type": {
      "$ref": "./common.schema.json#/$defs/activityType"
    },
    "activity_lane": {
      "$ref": "./common.schema.json#/$defs/activityLane"
    },
    "occurred_on": {
      "$ref": "./common.schema.json#/$defs/isoDate"
    },
    "source_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/sourceRef"
      },
      "uniqueItems": true
    },
    "external_urls": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/url"
      },
      "uniqueItems": true
    },
    "scope_label": {
      "type": "string",
      "description": "Display label for field-wide or cross-cutting activity that should not be forced into one hallmark or track."
    },
    "noteworthiness_tier": {
      "enum": [
        "field_anchor",
        "material_program",
        "watch_only",
        "below_threshold"
      ]
    },
    "threshold_basis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "new_major_entity",
          "major_dedicated_funding",
          "major_prize_or_funder_program",
          "field_infrastructure",
          "clinical_transition",
          "major_partnership",
          "regulatory_or_safety_signal",
          "direct_track_relevance",
          "source_quality_gap",
          "routine_or_minor"
        ]
      },
      "uniqueItems": true
    },
    "trial_activity_kind": {
      "enum": [
        "new_direct_human_trial",
        "first_in_human_or_older_adult",
        "material_status_change",
        "completion_or_termination",
        "results_posted_or_published",
        "major_phase_or_program_transition",
        "trial_watch_anchor",
        "routine_registry_maintenance"
      ]
    },
    "hallmark_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/hallmarkRef"
      },
      "uniqueItems": true
    },
    "track_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/trackRef"
      },
      "uniqueItems": true
    },
    "intervention_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/interventionRef"
      },
      "uniqueItems": true
    },
    "study_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/studyRef"
      },
      "uniqueItems": true
    },
    "finding_ids": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/findingRef"
      },
      "uniqueItems": true
    },
    "significance_note": {
      "type": "string"
    },
    "surface_routing": {
      "$ref": "#/$defs/surfaceRouting"
    },
    "affects_outlook": {
      "type": "boolean"
    }
  },
  "$defs": {
    "surfaceRouting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affected_surfaces",
        "state_of_field_review_required",
        "current_story_review_required",
        "rationale"
      ],
      "properties": {
        "affected_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "activity_feed",
              "state_of_field",
              "current_lev_story",
              "hallmark_insight",
              "track_page",
              "overall_outlook",
              "trial_horizon",
              "evidence_record",
              "no_public_surface"
            ]
          },
          "uniqueItems": true
        },
        "state_of_field_review_required": {
          "type": "boolean"
        },
        "current_story_review_required": {
          "type": "boolean"
        },
        "no_surface_change_reason": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        }
      }
    }
  }
}
