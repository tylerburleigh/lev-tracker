{
  "schema_version": "1.0.0",
  "taxonomy": "hallmark_tracks",
  "taxonomy_version": "1.0.0",
  "description": "Seed track taxonomy for the Hallmarks of Aging LEV Tracker. Tracks are the stable working layer between hallmarks and specific interventions.",
  "design_notes": [
    "A track should be broader than one intervention and narrower than a hallmark.",
    "This is a seeded editorial taxonomy, not a claim of scientific consensus.",
    "Tracks may be split or merged later as evidence density and curator needs change.",
    "Measurement methods and biomarkers are not tracks unless they are part of an intervention program.",
    "Company activity, regulation, and funding belong in activity items, not in this taxonomy."
  ],
  "source_basis": [
    {
      "title": "Hallmarks of aging: An expanding universe",
